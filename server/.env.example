# Server
PORT=5000
NODE_ENV=development

# Database (Render PostgreSQL "External Database URL" or local)
DATABASE_URL=postgres://username:password@localhost:5432/tutorium
DB_SSL=false

# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Teacher account bootstrap (used only by seed / first-run registration)
DEFAULT_INSTITUTE_NAME=Tutorium
DEFAULT_CURRENCY=BDT

# Email (for OTP / password reset) - optional, using Gmail SMTP example
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Tutorium <no-reply@tutorium.app>"

# SMS OTP provider (optional) - leave blank to disable SMS OTP
SMS_API_KEY=
SMS_SENDER_ID=

# File uploads
MAX_UPLOAD_MB=5
